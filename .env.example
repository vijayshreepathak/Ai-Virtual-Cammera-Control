# OpenAI (optional if using Gemini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# Gemini — get key at https://aistudio.google.com/apikey (MUST start with AIza, NOT AQ.)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LLM provider: openai | gemini
LLM_PROVIDER=gemini

# Speech-to-text: gemini | openai (cloud) | faster-whisper (local, slow first run)
STT_BACKEND=gemini
WHISPER_MODEL_SIZE=tiny
