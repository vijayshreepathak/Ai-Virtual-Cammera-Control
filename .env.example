# OpenAI (optional if using Gemini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1

# Gemini (optional if using OpenAI)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LLM provider: openai | gemini (auto-detected from keys if omitted)
LLM_PROVIDER=

# Speech-to-text backend: openai (fast, needs key) | faster-whisper (local, slow first run)
STT_BACKEND=openai
WHISPER_MODEL_SIZE=tiny
